{
  "name": "olympus",
  "version": "0.1.0",
  "private": true,
  "description": "Olympus — the Autonomous Business Operating System (ABOS). Core reference skeleton.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "demo": "tsx core/demo.ts",
    "serve": "tsx core/api/server.ts",
    "test": "node --import tsx/esm --test core/tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0"
  }
}
